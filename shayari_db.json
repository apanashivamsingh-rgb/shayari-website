{
    "shayaris": [
        {
            "title": "\u0924\u0942 \u0939\u0948 \u0930\u093e\u092e, \u092e\u0948\u0902 \u0930\u093e\u0935\u0923 \u0939\u0942",
            "content": "\u092c\u0947\u0936\u0930\u094d\u092e \u0939\u0948, \u092c\u091a\u094d\u091a\u0932\u0928 \u0939\u0948 \n\u0915\u093f\u0924\u0928\u094b \u0915\u0947 \u0938\u093e\u0925 \u092e\u0947\u0902 \u0938\u094b\u0908 \u0939\u0948\n\u0915\u093f\u0928 \u0915\u093f\u0928 \u0939\u093e\u0925\u094b \u0915\u094b \u0925\u092e\u0940 \u0939\u0948\n\u0915\u093f\u0928 \u0915\u093f\u0928 \u0915\u0947 \u0938\u0902\u0917 \u092e\u0947\u0902 \u0939\u094b\u0908 \u0939\u0948\n\u0932\u094b\u0917\u094b \u0915\u0940 \u092c\u093e\u0924\u0947 \u0938\u0941\u0928  \u0938\u0941\u0928 \u0915\u0930 \n\u0905\u0917\u0930 \u0924\u0942 \u092d\u0940 \u0921\u0930 \u0921\u0930 \u091c\u0940\u0924\u093e \u0939\u094b\u0902\n\u0924\u094b \u092b\u093f\u0930\n\u0915\u0942\u0926\u093e \u0926\u0947 \u0905\u0917\u094d\u0928\u093f \u092e\u0947\u0902 \u0905\u092a\u0928\u0940 \u0905\u0930\u094d\u0927\u0917\u094d\u0928\u093f \u0938\u0940\u0924\u093e \u0915\u094b \n\u092e\u0948\u0902 \u0939\u0942 \u0926\u0936\u093e\u0928\u0928 \u0932\u0902\u0915\u093e \u0915\u093e ,\u092e\u0948\u0902 \u0924\u0941\u091d\u0938\u093e \u092a\u0924\u093f \u0928\u093e \u092a\u093e\u0935\u0928 \u0939\u0942\n\u091a\u0932 \u092e\u093e\u0928 \u0932\u093f\u092f\u093e \u092f\u0947 \u0938\u0924\u092f\u0941\u0917 \u0939\u0948 \n\u0924\u0942 \u0939\u0948 \u0930\u093e\u092e \u092e\u0948\u0902 \u0930\u093e\u0935\u0923 \u0939\u0942\u0964\n\u0938\u0941\u0928\u093e \u0939\u0942 \u092e\u0948  \u0928\u093e\u0930\u0926 \u0915\u0932\u092f\u0941\u0917 \u0915\u0947 ,\u0930\u093e\u092e \u092c\u0941\u0932\u093e\u0915\u0930 \u0932\u093e\u090f \u0939\u0948\n\u091a\u0939\u0930\u093e \u0915\u093f\u0938\u0940 \u0915\u093e \u0932\u0940\u092a \u092a\u094b\u0924 \u0915\u0930 \u092e\u0941\u091d\u0947 \u091c\u0932\u093e\u0928\u0947 \u0906\u090f \u0939\u0948\n \u091c\u094b \u0939\u093e\u0925 \u092e\u0947\u0902 \u0932\u0947\u0915\u0930 \u092c\u093e\u0923 \u0916\u0921\u093c\u093e \u0939\u0948 \u0909\u0938\u0915\u094b \u092d\u0940 \u0936\u094d\u0930\u0940 \u0930\u093e\u092e \u0926\u093f\u0916\u093e \u0926\u094b\n\u091c\u094b \u092c\u093e\u0923 \u0915\u0947 \u090a\u092a\u0930 \u0906\u0917 \u091a\u0922\u093c\u0940 \u0939\u0948 \u0909\u0938\u0915\u094b \u092d\u0940 \u092a\u0930\u093f\u0923\u093e\u092e \u0926\u093f\u0916\u093e \u0926\u094b\n\u092e\u0947\u0930\u0947 \u0915\u0942\u0932 \u092a\u0930 \u0906\u0902\u091a \u091c\u094b \u0906\u0908 \u092b\u093f\u0930 \u0938\u0947 \u092e\u0947\u0902 \u0939\u0941\u0902\u0915\u093e\u0930 \u092d\u0930\u0942\u0902\u0917\u093e\n\u0930\u093e\u092e \u092d\u0947\u0938 \u092e\u0947\u0902 \u091c\u094b \u0930\u093e\u092e \u091a\u0932\u093e \u0939\u0948 \u0909\u0938\u0915\u093e \u092b\u093f\u0930 \u0909\u0926\u094d\u0927\u093e\u0930 \u0915\u0930\u0942\u0902\u0917\u093e\u0964\n\u0939\u0947 \u0930\u093e\u092e \u0938\u0941\u0928\u094b \u0939\u0947 \u0930\u093e\u092e \u0938\u0941\u0928\u094b , \u0939\u0947 \u0938\u0924\u092f\u0941\u0917  \u0915\u0947 \u0905\u092d\u093f\u092e\u093e\u0928 \u0938\u0941\u0928\u094b\n\u0913 \u091a\u0940\u0916 \u0915\u0940 \u0917\u0942\u0902\u091c\u0940 \u0924\u093e\u0928 \u0938\u0941\u0928\u094b\n\u0914\u0930 \u092e\u0941\u091d\u0947 \u091a\u0940\u0930\u0924\u0947 \u092c\u093e\u0923 \u0938\u0941\u0928\u094b\n\u092e\u0948\u0902 \u0930\u093e\u0935\u0923 \u0939\u0942 \u092e\u0948 \u0930\u093e\u0935\u0923 \u0939\u0942 ,\u092e\u0948\u0902 \u0905\u0924\u093f \u0915\u094d\u0930\u0942\u0930 \u0928\u093f\u0930\u094d\u0926\u0908 \u0939\u0942\n\u092e\u0948\u0902 \u0939\u0942 \u0935\u091a\u0928 \u0909\u0938 \u0930\u0916\u0940 \u0915\u093e \u092e\u0948\u0902 \u0938\u0941\u092a\u0930\u094d\u0923\u0916\u093e \u0915\u093e \u092d\u093e\u0908 \u0939\u0942\n\u0928\u093e \u0925\u0940 \u0913 \u0915\u094b\u0908 \u092a\u0930\u093e\u092f\u093e \u0927\u0928 \u0928\u093e \u092c\u094b\u091d \u0925\u0940 \u092e\u0947\u0930\u0940 \u091b\u093e\u0924\u0940 \u092a\u0930\n\u0924\u0942 \u0932\u0917\u093e \u0939\u093e\u0925 \u0914\u0930 \u0926\u0947\u0916 \u092e\u0948\u0902 \u092b\u093f\u0930 \u0938\u0947 \u0932\u093e\u090a\u0902\u0917\u093e \u092e\u0938\u094d\u0924\u0915 \u092e\u093e\u091f\u0940 \u092a\u0930 \u0964\n\u0907\u0938 \u0915\u0932\u092f\u0941\u0917 \u0915\u0947 \u0930\u093e\u092e\u093e\u092f\u0923 \u092e\u0947\u0902 \u092e\u0948\u0902 \u090f\u0915 \u0928\u092f\u093e \u0905\u0927\u094d\u092f\u093e\u092f \u0932\u093f\u0916\u0942\u0902\u0917\u093e\n\u0916\u0941\u0926 \u092c\u0928\u0942\u0902\u0917\u093e \u0926\u0938\u0930\u0925 \u092e\u0948\u0902 \u0915\u0948\u0915\u0947\u0908 \u0915\u0940 \u090f\u0915 \u0938\u0941\u0928\u0942\u0902\u0917\u093e \n\u092a\u094d\u0930\u093e\u0923 \u091c\u093e\u090f \u0914\u0930 \u0935\u091a\u0928 \u0928 \u091c\u093e\u0908 \u0907\u0938 \u0905\u0939\u0902\u0915\u093e\u0930 \u0915\u093e \u0928\u093e\u0938 \u0915\u0930\u0942\u0902\u0917\u093e\n\u0938\u0940\u0924\u093e \u0915\u0947 \u0915\u0930\u0921\u093c\u0947  \u0938\u0947 \u092a\u0939\u0932\u0947 \u0927\u0930\u0924\u0940 \u0915\u094b \u0905\u0915\u093e\u0938 \u0915\u0930\u0942\u0902\u0917\u093e\n\u092e\u0948\u0902 \u0926\u0938\u093e\u0928\u0928 \u0932\u0902\u0915\u093e \u0915\u093e \u092e\u0948\u0902 \u0924\u0941\u091d\u0938\u093e \u092a\u0924\u093f \u0928\u093e \u092a\u093e\u0935\u0928 \u0939\u0942\n\u0914\u0930 \u0939\u0935\u0938 \u092d\u0930\u0947 \u0907\u0938 \u0915\u0932\u092f\u0941\u0917 \u092e\u0947\u0902 \u0939\u0930 \u0938\u0941\u092a\u0930\u094d\u0923\u0916\u093e \u0915\u093e \u092d\u093e\u0908 \u0939\u0942",
            "date": "01 May, 2026"
        },
        {
            "title": "JAY SHREE RAM",
            "content": "\u092d\u0917\u0935\u093e\u0928 \u0935\u093f\u0937\u094d\u0923\u0941 \u0915\u0947 7\u0935\u0947\u0902 \u0905\u0935\u0924\u093e\u0930 \u0915\u0947 \u0930\u0942\u092a \u092e\u0947\u0902 \u0905\u092f\u094b\u0927\u094d\u092f\u093e \u0915\u0947 \u0930\u093e\u091c\u093e \u0926\u0936\u0930\u0925 \u0914\u0930 \u0930\u093e\u0928\u0940 \u0915\u094c\u0936\u0932\u094d\u092f\u093e \u0915\u0947 \u0918\u0930 \u0909\u0928\u0915\u0947 \u091c\u0928\u094d\u092e \u0938\u0947 \u0936\u0941\u0930\u0942 \u0939\u094b\u0924\u0940 \u0939\u0948\u0964 \u092f\u0939 \u090f\u0915 \u0906\u0926\u0930\u094d\u0936 \u092a\u0941\u0930\u0941\u0937, \u092a\u0941\u0924\u094d\u0930, \u092a\u0924\u093f \u0914\u0930 \u0930\u093e\u091c\u093e \u0915\u0940 \u0915\u0925\u093e \u0939\u0948 \u091c\u094b \u0938\u0924\u094d\u092f, \u0927\u0930\u094d\u092e \u0914\u0930 \u092e\u0930\u094d\u092f\u093e\u0926\u093e (\u092e\u0930\u094d\u092f\u093e\u0926\u093e \u092a\u0941\u0930\u0941\u0937\u094b\u0924\u094d\u0924\u092e) \u0915\u093e \u092a\u093e\u0932\u0928 \u0915\u0930\u0924\u0947 \u0939\u0941\u090f 14 \u0935\u0930\u094d\u0937 \u0915\u0947 \u0935\u0928\u0935\u093e\u0938, \u0938\u0940\u0924\u093e \u0939\u0930\u0923 \u0914\u0930 \u0930\u093e\u0935\u0923 \u0935\u0927 \u0915\u0947 \u092c\u093e\u0926 \u092a\u0941\u0928\u0903 \u0905\u092f\u094b\u0927\u094d\u092f\u093e \u0932\u094c\u091f\u0915\u0930 \u0930\u093e\u092e\u0930\u093e\u091c\u094d\u092f \u0915\u0940 \u0938\u094d\u0925\u093e\u092a\u0928\u093e \u0915\u0930\u0924\u0947 \u0939\u0948\u0902\u0964",
            "date": "01 May, 2026"
        }
    ],
